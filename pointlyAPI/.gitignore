# Create .gitignore
cat > .gitignore << 'EOF'
# Database files
*.db
*.db-shm
*.db-wal

# Build results
bin/
obj/
*.dll
*.exe
*.pdb

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetRider Rider
.idea/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Logs
*.log

# OS files
.DS_Store
Thumbs.db
EOF